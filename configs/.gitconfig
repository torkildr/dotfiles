[user]
	name = Torkild Retvedt
	email = torkild@retvedt.no
[push]
  default = simple
  followTags = true
[alias]
  lg = log --graph --pretty=format:'%Cred%h%Creset -%C(bold yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset'
  st = status
  t = tag --format '%(color:green)%(refname:short)%(color:reset) %(taggerdate) (%(taggername))' --sort taggerdate
  stat = !"git shortlog -sn|sort -n"
  find = log --full-history --all -p -G
  mostchanged = !"git log --format=format: --name-only --since=\"1 year ago\" | sort | uniq -c | sort -nr | head -20"
  whochanged = !"git shortlog -sn --no-merges"
  mostbug = !"git log -i -E --grep=\"fix|bug|broken\" --name-only --format='' | sort | uniq -c | sort -nr | head -20"
  velocity = !"git log --format='%ad' --date=format:'%Y-%m' | sort | uniq -c"
[core]
  excludesfile = ~/.gitignore_global
  whitespace = trailing-space,-space-before-ta
	pager = diff-so-fancy | less --tabs=4 -RFX
[merge]
  ff = only
[mergetool "code"]
  path = ~bin/code
[difftool "code"]
  path = ~bin/code
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
[commit]
  template = ~/.gitcommitmsg
[pull]
  ff = only
[init]
	defaultBranch = main
[http]
  postBuffer = 1048576000
[includeIf "gitdir:~/work/"]
  path = ~/work/.gitconfig

[interactive]
	diffFilter = diff-so-fancy --patch
